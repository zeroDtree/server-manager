# Copy to .env and edit non-secret config. Then run ./utils/secret.sh to create .env.secrets.

# dev (default) | prod
SPRING_PROFILES_ACTIVE=dev

# Public hostname for Traefik Host() rules and DNS (prod HTTPS; use localhost for prod-local)
GSAD_PUBLIC_HOST=gsad.example.com

# Let's Encrypt registration email (required for prod HTTPS)
ACME_EMAIL=admin@example.com

# Host port for GPU agents to reach backend internal API (default 8080)
BACKEND_AGENT_PORT=8080

# Bind address for agent port (required with compose.prod.yaml)
BACKEND_AGENT_BIND=127.0.0.1

# Comma-separated overlay VPN CIDRs (e.g. NetBird). Required when BACKEND_AGENT_BIND is a VPN IP.
BACKEND_AGENT_VPN_CIDRS=
# Example: BACKEND_AGENT_VPN_CIDRS=100.67.0.0/16

# Optional prod CORS (comma-separated origins); leave empty when frontend and API share
# the same https://${GSAD_PUBLIC_HOST} origin via Traefik
CORS_ALLOWED_ORIGINS=

# External edge Traefik (deploy-prod.sh --external). Docker network your edge Traefik uses.
# Example: NetBird netbird-traefik on network "netbird" → TRAEFIK_EXTERNAL_NETWORK=netbird
TRAEFIK_EXTERNAL_NETWORK=
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# --- account_prepare (student onboarding; see account_prepare/README.md) ---

# Self-hosted NetBird API base URL — must include scheme. Omit for NetBird Cloud default.
NETBIRD_API_BASE=https://netbird.example.com

# Full GSAD login URL for credential emails (notify)
GSAD_PUBLIC_URL=https://gsad.example.com/

# Optional NetBird dashboard link in onboarding email
NETBIRD_DASHBOARD_URL=https://netbird.example.com/

# SMTP for notify --send (SMTP_PASSWORD in .env.secrets)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notify@example.com
# SMTP_FROM defaults to SMTP_USER; set only when the visible From address differs
# SMTP_SSL=0
# SMTP_USE_TLS=1
# SMTP_DELAY_SECONDS=1

# Secrets (DB_PASSWORD, JWT_SECRET, etc.) live in .env.secrets — generated by ./utils/secret.sh
